# Same-origin reverse proxy for deploy.
#
# The browser opens Gogglebox at this one origin. /player is stripped and
# forwarded to the normal Jellyfin origin.
{
	auto_https off
	admin off
}

:8080 {
	handle /api/* {
		reverse_proxy gogglebox:3000
	}

	handle_path /player/* {
		reverse_proxy {$JELLYFIN_URL}
	}

	handle {
		reverse_proxy gogglebox:3000
	}
}
