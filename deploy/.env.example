# Gogglebox deployment env — copy to deploy/.env and fill in.
# Used by: docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d

# --- Required (compose refuses to start if any is unset) ---

# Host port to expose. Maps to the proxy front door's internal port 8080.
GOGGLEBOX_PORT=3000

# Jellyfin server the portal reads library + watch state from. Caddy also proxies
# /player to this origin after stripping the /player prefix. Do not include a
# /player base path here.
JELLYFIN_URL=https://jellyfin.example.com
JELLYFIN_API_KEY=replace-me

# Long random string used to sign session cookies. Generate one, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# --- Optional ---

# Image tag to pull. Pin to a yyyymmddhhmmss version tag for reproducible
# deploys; leave as latest to always pull the newest published image.
GOGGLEBOX_VERSION=latest

# Host directory for writable app state (the ignored-shows map). Bind-mounted
# into the container so it survives redeploys. Must be writable by uid 1000
# (the container's non-root user) — chown it once after first deploy:
#   sudo chown -R 1000:1000 /var/lib/gogglebox
# Relative paths resolve against deploy/; use an absolute path in production.
GOGGLEBOX_STATE_DIR=/var/lib/gogglebox

# Fraction of an item that must be watched before it counts as watched.
# Overrides the value in config if set.
# WATCHED_THRESHOLD=0.9

# Optional auto-login. When set AND matching an access_tokens entry in
# config.json, that token's account is logged in automatically (skipping the
# login screen). Leave unset to always show the login screen.
ACCESS_TOKEN=replace-with-an-access-token

# Log all outbound Jellyfin requests with timing + item counts. Useful for
# diagnosing Jellyfin load; leave false in normal operation.
JELLYFIN_DEBUG=false

# GO Feature Flag sidecar. The default flag file is the repo's production-safe
# ../flags/goff.yaml, so changing flag state can be a repo commit plus compose
# refresh without rebuilding the Gogglebox image.
GOFF_API_KEY=gogglebox-local
GOFF_TIMEOUT_MS=1500
# GOFF_FLAGS_FILE=../flags/goff.yaml
