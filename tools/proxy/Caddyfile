# Same-origin reverse proxy — the shipped front door for Gogglebox.
#
# Everything is served from ONE origin (http://localhost:8080) so that the
# gbx client JS (served at /) and Jellyfin-web (served at /player) share a
# localStorage origin. That lets the client seed Jellyfin-web's credentials
# for the same origin, so opening /player in a new tab auto-logs-in as a
# gbx-controlled, per-party Jellyfin user.
#
# Routes:
#   /api/*    -> gbx server  (Express :3000)
#   /player/* -> Jellyfin    (strip /player, then proxy to {$JELLYFIN_URL})
#   /*        -> gbx client  (Vite dev :5173, with HMR websockets)
#
# `JELLYFIN_URL` is the normal Jellyfin origin, without a /player base path.

{
	# No HTTPS/ACME for the LAN dev front door.
	auto_https off
	admin off
}

:8080 {
	# gbx API.
	handle /api/* {
		reverse_proxy server:3000
	}

	# Jellyfin, mounted by Gogglebox at /player. Jellyfin itself stays on its
	# normal origin/base path; the proxy strips /player before forwarding.
	handle_path /player/* {
		reverse_proxy {$JELLYFIN_URL:http://jellyfin-unconfigured:8096}
	}

	# Everything else -> the Vite dev client. reverse_proxy transparently
	# upgrades websockets, so Vite HMR (/@vite/client) works through the proxy.
	handle {
		reverse_proxy client:5173
	}
}
