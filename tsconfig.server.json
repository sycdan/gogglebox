{
	"compilerOptions": {
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"module": "Node16",
		"moduleResolution": "Node16",
		"rootDir": "src/server",
		"outDir": "dist/server",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": [
			"node"
		]
	},
	"include": [
		"src/server/**/*.ts"
	]
}