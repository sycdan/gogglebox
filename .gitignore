node_modules
dist
.vite
artifacts
data
.env
!.env.example
config.json
!package-lock.json

# UAT stack (real Jellyfin): local secrets + household config stay out of git.
# Copy the templates from .env.example and deploy/config.example.json.
.env.uat
config.uat.json

# Sandbox Jellyfin: generated artifacts stay out of git (regenerate on demand).
# The generator/provisioner/reset scripts + .nfo templates ARE committed; the
# media + Jellyfin config live in named volumes, not the tree. .env.sbx is
# minted secrets (the provisioned API key) — never commit it.
.env.sbx
config.sbx.json
tools/sandbox/media/

# Stray file created when a command redirects to `nul` (Windows null-device
# name) inside the POSIX Bash tool, where it's a literal file not /dev/null.
nul

# Global gitignore ignores .claude/; re-include only the shared project subagents
# (local .claude settings stay ignored).
!.claude/
.claude/*
!.claude/agents/

# Effort work sessions
sessions/*
