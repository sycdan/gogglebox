# Shared env template — copy to .env. This holds config common to every stack.
#
# Layered scheme: .env is the shared base; the sbx/uat run stacks append an
# overrides-only .env.<env> on top (later file wins) for the four
# connection/identity vars below. Those are NOT set here — they live per-env:
#   .env.sbx — GENERATED by `./scripts/sbx.sh run --rm sandbox-provision`
#   .env.uat — you CREATE by hand with your real Jellyfin + household values:
#       JELLYFIN_URL=https://your-real-jellyfin
#       JELLYFIN_API_KEY=...
#       PORTAL_USERNAME=...
#       PORTAL_PASSWORD=...

# Image publish (docker-publish.sh / pre-push hook)
REGISTRY_HOST=registry.example.com:5000

# Session cookie signing secret.
SESSION_SECRET=replace-with-a-long-random-secret

# Optional overrides
WATCHED_THRESHOLD=0.9
PORTAL_AUTO_LOGIN=false
# Set to true or 1 to log all outbound Jellyfin requests with timing and item counts
# Also logs API request timing and stream lifecycle events — useful for diagnosing Jellyfin load
JELLYFIN_DEBUG=false

# Dev (docker-compose.yml) only — usually leave the defaults.
# Vite proxy target for the client service (set automatically in dev compose).
VITE_API_PROXY=http://server:3000
# Dev-only iframe playback workaround: start Jellyfin-web videos muted so Chrome
# allows automated visual playback. Leave deploy/.env unset for normal audio.
VITE_PLAYER_START_MUTED=true
# URL the Playwright proof service drives.
PROOF_URL=http://client:5173
