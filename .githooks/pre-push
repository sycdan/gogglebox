#!/usr/bin/env bash
# pre-push gate: refuse to push unless the tree is clean, the typecheck
# ("lint") passes, and the production image builds. Publishing is handled by
# CI (GitHub Actions -> GHCR), so this hook only proves the image builds; it
# does not push. The push only proceeds if every step is green.
#
# Everything runs in Docker (the host has only docker + git, per CLAUDE.md).
# There is no eslint in this repo, so "lint" == the typecheck (`npm run check`).
#
# Install (once, per clone):  git config core.hooksPath .githooks
set -euo pipefail

compose="docker compose -f docker-compose.yml"

echo "[pre-push] 1/3 working tree clean?"
if [[ -n "$(git status --porcelain)" ]]; then
	echo "[pre-push] FAIL: working tree is dirty — commit or stash first." >&2
	git status --short >&2
	exit 1
fi

echo "[pre-push] 2/3 typecheck (lint)…"
# `check` needs no Jellyfin/portal creds, but compose parses the whole file
# and some services declare required (:?) vars — stub them so interpolation
# doesn't abort the run.
export PORTAL_USERNAME="${PORTAL_USERNAME:-prepush}"
export PORTAL_PASSWORD="${PORTAL_PASSWORD:-prepush}"
$compose run --rm check

echo "[pre-push] 3/3 production image builds…"
# Build gate only — CI publishes to GHCR after the push lands. Build the same
# image the Dockerfile produces; fail the push if it doesn't build.
docker build -t gogglebox:prepush .

echo "[pre-push] all green — proceeding with push."
